{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "UI Dev",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "runtimeVersion": "24.15.0",
      "env": {
        "NODE_OPTIONS": "--experimental-require-module"
      }
    },
    {
      "name": "UI Build",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "runtimeVersion": "24.15.0",
      "env": {
        "NODE_OPTIONS": "--experimental-require-module"
      }
    },
    {
      "name": "UI Preview",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "runtimeVersion": "24.15.0",
      "env": {
        "NODE_OPTIONS": "--experimental-require-module"
      }
    },
    {
      "name": "UI Generate CSP Script Hashes",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "generate:csp-script-hashes"],
      "runtimeVersion": "24.15.0"
    },
    {
      "name": "UI Unit Tests",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test:unit:watch"],
      "runtimeVersion": "24.15.0",
      "env": {
        "NODE_OPTIONS": "--experimental-require-module"
      }
    },
    {
      "name": "UI E2E Tests",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test:e2e:ui"],
      "runtimeVersion": "24.15.0",
      "env": {
        "NODE_OPTIONS": "--experimental-require-module"
      }
    },
    {
      "name": "UI Storybook",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "storybook"],
      "runtimeVersion": "24.15.0",
      "env": {
        "NODE_OPTIONS": "--experimental-require-module"
      }
    }
  ]
}
